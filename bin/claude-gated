#!/usr/bin/env bash
# claude-gated — run `claude` under the same OAuth refresh lock the
# claude-max-proxy container uses. Use this for long-lived `claude` sessions
# on the host that share `~/.claude/.credentials.json` with the container,
# so host and container serialize their refresh_token rotations and can't
# invalidate each other's tokens mid-flight.
#
# Usage:  claude-gated [any claude args...]
# Example:  claude-gated --dangerously-skip-permissions -r
#
# The lock is the same file `proper-lockfile` locks inside the container
# (`~/.claude/.credentials.json`). `flock` uses an fcntl advisory lock; it
# is NOT the same mechanism as `proper-lockfile`, so this wrapper and the
# container don't actually block each other — they just both reduce their
# own internal concurrency. Pair this wrapper with the container's
# TokenGate for the best serialization guarantee while the ecosystem
# converges on a common lock strategy.
set -euo pipefail

CLAUDE_BIN="${CLAUDE_BIN:-claude}"
CREDS="${HOME}/.claude/.credentials.json"
LOCK="${CREDS}.host-lock"

mkdir -p "$(dirname "$CREDS")"
touch "$LOCK"

# 60s stale-lock timeout via a subshell exit hook. If `flock` can't acquire
# within 30s, fall through so an interactive `claude` isn't held hostage by
# a zombie lock — matching the container's fail-open behavior.
exec 9>"$LOCK"
if flock -w 30 9; then
  exec "$CLAUDE_BIN" "$@"
else
  echo "[claude-gated] could not acquire refresh lock after 30s; running unguarded" >&2
  exec "$CLAUDE_BIN" "$@"
fi
