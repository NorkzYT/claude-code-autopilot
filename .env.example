# Docker OpenClaw defaults
# Host directory containing repositories - mounted at the same path inside the container
# Change this if your repos are in a different location (e.g., /opt/github, /home/user/projects)
HOST_REPOS_DIR=/opt/repos
OPENCLAW_GATEWAY_PORT=18789
# Gateway bind mode: "all" (all interfaces, required for Tailscale), "lan" (LAN only), or "loopback" (localhost only)
OPENCLAW_GATEWAY_BIND=all
OPENCLAW_VNC_PORT=5900
OPENCLAW_VIEWER_PORT=6080
OPENCLAW_BROWSER_HEADLESS=false
OPENCLAW_BROWSER_DEBUG_PORT=18800
# Host services are reachable from the container at host.docker.internal:<port>

# Override the default host state path (~/.openclaw) — auto-set by installer
# OPENCLAW_HOST_STATE_DIR=/home/your-user/.openclaw

# Match container node user to host user (auto-set by installer)
# PUID=1000
# PGID=1000

# Git identity used inside the OpenClaw container for repo work
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com
GIT_COMMITTER_NAME=Your Name
GIT_COMMITTER_EMAIL=you@example.com

# Optional OpenClaw auth and routing configuration
OPENCLAW_THINKING_DEFAULT=high
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-6
OPENCLAW_MODEL_FALLBACKS=["openai/gpt-5.3-codex","openai/gpt-5.4"]

# Extra allowed origins for the gateway control UI (comma-separated, no spaces)
# Localhost origins (with port) are always included automatically.
# Example: OPENCLAW_EXTRA_ORIGINS=https://my-host.tail63ecc.ts.net,https://other-host.example.com
OPENCLAW_EXTRA_ORIGINS=

# Browser isolation: "shared" (default, single browser) or "per-agent" (isolated display per agent)
# Per-agent mode gives each agent its own Xvfb display, Chromium profile, and CDP port.
# Requires: make rebuild after changing.
OPENCLAW_BROWSER_ISOLATION=shared

# Claude Max API Proxy (provides OpenAI-compatible API using your Claude Max subscription)
# Path to the claude-max-api-proxy repo (cloned during setup)
# CLAUDE_MAX_PROXY_DIR=./claude-max-api-proxy
# CLAUDE_MAX_PROXY_PORT=3456
# Default extended-thinking budget applied to every request (OpenClaw's thinkingDefault
# is not forwarded to OpenAI-compatible providers). Values: minimal, low, medium, high, max,
# or an integer token count. Leave unset to disable extended thinking by default.
# DEFAULT_THINKING_BUDGET=high

# Browser viewer and manual login session behavior
OPENCLAW_BROWSER_WIDTH=1920
OPENCLAW_BROWSER_HEIGHT=1080
OPENCLAW_BROWSER_DOWNLOADS_DIR=/home/node/.openclaw/downloads
