# Docker OpenClaw defaults
HOST_REPOS_DIR=/opt/repos
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=all
OPENCLAW_VNC_PORT=5900
OPENCLAW_VIEWER_PORT=6080
OPENCLAW_BROWSER_HEADLESS=false
OPENCLAW_BROWSER_DEBUG_PORT=18800
# Host services are reachable from the container at host.docker.internal:<port>

# Optional: override the default host state path (~/.openclaw)
# OPENCLAW_HOST_STATE_DIR=/home/your-user/.openclaw

# Git identity used inside the OpenClaw container for repo work
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com
GIT_COMMITTER_NAME=Your Name
GIT_COMMITTER_EMAIL=you@example.com

# Optional OpenClaw auth and routing configuration
OPENCLAW_THINKING_DEFAULT=high
OPENCLAW_ANTHROPIC_SETUP_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-6
OPENCLAW_MODEL_FALLBACKS=["openai/gpt-5.3-codex","openai/gpt-5.4"]

# Browser viewer and manual login session behavior
OPENCLAW_BROWSER_WIDTH=1920
OPENCLAW_BROWSER_HEIGHT=1080
OPENCLAW_BROWSER_DOWNLOADS_DIR=/home/node/.openclaw/downloads
