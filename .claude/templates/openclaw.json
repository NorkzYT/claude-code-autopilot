{
  "$schema": "https://openclaw.dev/schema/config.json",
  "agents": {
    "defaults": {
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "browser": {
    "enabled": true,
    "headless": true
  },
  "messages": {
    "groupChat": {
      "historyLimit": 20
    }
  },
  "cron": {
    "enabled": true
  },
  "channels": {
    "discord": {
      "enabled": false
    }
  }
}
