{
  "$schema": "https://openclaw.dev/schema/config.json",
  "agents": {
    "defaults": {
      "timeoutSeconds": 7200,
      "subagents": {
        "runTimeoutSeconds": 3600
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m"
      },
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-opus-4-7",
          "openai-codex/gpt-5.3-codex"
        ]
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "browser": {
    "enabled": true,
    "headless": true
  },
  "messages": {
    "groupChat": {
      "historyLimit": 20
    }
  },
  "cron": {
    "enabled": true
  },
  "channels": {
    "discord": {
      "enabled": false
    }
  }
}
