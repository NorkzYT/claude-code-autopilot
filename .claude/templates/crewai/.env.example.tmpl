# LLM mode
# - direct: call provider APIs directly with provider API keys
# - proxy: call local CLIProxyAPI (subscription-backed routing)
CREWAI_LLM_MODE=proxy

# Direct provider credentials (used when CREWAI_LLM_MODE=direct)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# CLIProxyAPI local OpenAI-compatible endpoint (used when CREWAI_LLM_MODE=proxy)
# Start proxy with: bash .claude/scripts/crewai-cliproxyapi.sh up
OPENAI_BASE_URL=http://127.0.0.1:8317/v1
OPENAI_API_BASE=http://127.0.0.1:8317/v1
CLI_PROXY_BASE_URL=http://127.0.0.1:8317/v1
CLI_PROXY_API_KEY={{PROJECT_SLUG}}-crewai-local-key

# Optional model override for providers that support it
MARKETING_MODEL=gpt-5.3-codex

# Business context used by the crew
TOOL_NAME={{PROJECT_NAME}}
TOOL_TAGLINE=Help users solve a real workflow problem faster with clear measurable outcomes.
TARGET_PERSONA=Teams and individual operators who need better results with less manual effort.
PRIMARY_OFFER=Primary paid conversion path (for example: subscription, annual plan, or one-time purchase).
PRIMARY_GOAL=Increase qualified awareness, activation, and paying customers.
