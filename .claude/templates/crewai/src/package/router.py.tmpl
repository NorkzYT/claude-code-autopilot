"""
Task router — classifies task type and dispatches to the appropriate crew.

For "auto" tasks, a quick Codex call determines the best crew.
For explicit types (research, creative, personal, marketing, etc.),
dispatches directly to the matching crew (public or private).

Coding tasks return immediately — they are handled by engineering-loop.sh
directly via claude-max-proxy, not through this router.
"""
from __future__ import annotations

import json
import os
import urllib.error
import urllib.request

from .crews import get as get_crew, list_crews

CODING_TYPES = frozenset({"coding", "code", "engineering"})
KNOWN_TYPES = frozenset({"coding", "research", "creative", "personal", "marketing", "auto"})


def _classify_via_codex(task_description: str) -> str:
    """Ask Codex to classify the task into a crew type."""
    proxy_url = os.getenv("CLI_PROXY_BASE_URL", "http://127.0.0.1:8317/v1").rstrip("/")
    api_key = os.getenv("CLI_PROXY_API_KEY", os.getenv("OPENAI_API_KEY", "")).strip()
    model = os.getenv("ENGINEERING_MODEL", "gpt-5.3-codex")

    available = sorted(list_crews() or ["research", "creative"])
    valid = ", ".join(available)
    prompt = (
        f"Classify this task into exactly one category: {valid}.\n"
        f"Reply with only the category name — no explanation, no punctuation.\n\n"
        f"Task: {task_description[:1000]}"
    )

    payload = json.dumps(
        {"model": model, "messages": [{"role": "user", "content": prompt}], "stream": False}
    ).encode("utf-8")

    req = urllib.request.Request(
        f"{proxy_url}/chat/completions",
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = json.loads(resp.read().decode("utf-8"))
            raw = body["choices"][0]["message"]["content"].strip().lower()
            for name in available:
                if name in raw:
                    return name
    except Exception:  # noqa: BLE001
        pass

    return available[0] if available else "research"


def dispatch(task_description: str, task_type: str = "auto", **kwargs) -> str:
    """
    Route task_description to the correct crew and return the output string.

    Coding tasks are not executed here — the caller handles them via
    claude-max-proxy directly.
    """
    resolved = (task_type or "auto").strip().lower()

    if resolved in CODING_TYPES:
        return "(coding tasks are dispatched by engineering-loop.sh via claude-max-proxy)"

    if resolved == "auto":
        resolved = _classify_via_codex(task_description)

    # Exact match first, then partial, then first available, then research
    crew_fn = get_crew(resolved)
    if crew_fn is None:
        available = list_crews()
        for name in available:
            if resolved in name or name in resolved:
                crew_fn = get_crew(name)
                break
    if crew_fn is None:
        crew_fn = get_crew("research")
    if crew_fn is None:
        return (
            f"[router] no crew found for type '{resolved}'. "
            f"Available crews: {list_crews()}"
        )

    return crew_fn(task_description, **kwargs)
