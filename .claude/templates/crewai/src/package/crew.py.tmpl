import os

from crewai import Agent, Crew, LLM, Process, Task
from crewai.project import CrewBase, agent, crew, task


@CrewBase
class EngineeringPlannerCrew:
    """CrewAI team that turns an engineering task into a reviewed implementation plan."""

    agents_config = "config/agents.yaml"
    tasks_config = "config/tasks.yaml"

    def _llm(self) -> LLM:
        mode = os.getenv("CREWAI_LLM_MODE", "direct").strip().lower()
        model = os.getenv("ENGINEERING_MODEL", "gpt-5.3-codex")

        # Proxy mode routes through local OpenAI-compatible CLIProxyAPI.
        if mode == "proxy":
            proxy_key = os.getenv("CLI_PROXY_API_KEY", "").strip()
            if proxy_key and not os.getenv("OPENAI_API_KEY"):
                os.environ["OPENAI_API_KEY"] = proxy_key

            base_url = (
                os.getenv("OPENAI_BASE_URL", "").strip()
                or os.getenv("OPENAI_API_BASE", "").strip()
                or "http://127.0.0.1:8317/v1"
            )
            api_key = os.getenv("OPENAI_API_KEY", "").strip() or proxy_key
            llm_kwargs = {"model": model}
            if base_url:
                llm_kwargs["base_url"] = base_url
            if api_key:
                llm_kwargs["api_key"] = api_key
            return LLM(**llm_kwargs)

        return LLM(model=model)

    @agent
    def task_planner(self) -> Agent:
        return Agent(config=self.agents_config["task_planner"], verbose=True, llm=self._llm())

    @agent
    def plan_reviewer(self) -> Agent:
        return Agent(config=self.agents_config["plan_reviewer"], verbose=True, llm=self._llm())

    @task
    def plan_task(self) -> Task:
        return Task(config=self.tasks_config["plan_task"])

    @task
    def review_task(self) -> Task:
        return Task(config=self.tasks_config["review_task"])

    @crew
    def crew(self) -> Crew:
        return Crew(
            agents=self.agents,
            tasks=self.tasks,
            process=Process.sequential,
            verbose=True,
        )
