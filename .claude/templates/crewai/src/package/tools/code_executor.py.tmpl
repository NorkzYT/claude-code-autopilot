"""
CodeExecutorTool — bridge from CrewAI to the claude-max-proxy HTTP API.

Sends a coding prompt to the subscription-backed proxy (default:
http://localhost:3456) and returns the assistant's full text response.
The proxy internally runs Claude Code with --dangerously-skip-permissions,
so the prompt must instruct Claude to navigate to the working directory first.
"""
from __future__ import annotations

import json
import os
import urllib.error
import urllib.request
from typing import Any

from crewai.tools import BaseTool
from pydantic import BaseModel, Field


class CodeExecutorInput(BaseModel):
    prompt: str = Field(description="Full coding instruction to send to Claude Code via the proxy.")
    workspace: str = Field(
        default="",
        description="Absolute path to the repository workspace. Prepended to the prompt as a working directory instruction.",
    )


class CodeExecutorTool(BaseTool):
    name: str = "code_executor"
    description: str = (
        "Executes a coding task by forwarding the prompt to the local "
        "claude-max-proxy (subscription-backed Claude Code). "
        "Use this for any task that requires writing, editing, testing, or running code."
    )
    args_schema: type[BaseModel] = CodeExecutorInput

    def _run(self, prompt: str, workspace: str = "") -> str:
        proxy_url = os.getenv("CLAUDE_MAX_PROXY_URL", "http://localhost:3456").rstrip("/")
        model = os.getenv("ENGINEERING_CODE_MODEL", "claude-sonnet-4-6")

        full_prompt = prompt
        if workspace:
            full_prompt = (
                f"Working directory: {workspace}\n"
                f"Your first action must be to run: cd {workspace}\n\n"
                f"{prompt}"
            )

        payload = json.dumps(
            {
                "model": model,
                "messages": [{"role": "user", "content": full_prompt}],
                "stream": False,
            }
        ).encode("utf-8")

        req = urllib.request.Request(
            f"{proxy_url}/v1/chat/completions",
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST",
        )

        try:
            with urllib.request.urlopen(req, timeout=3600) as resp:
                body = json.loads(resp.read().decode("utf-8"))
                return body["choices"][0]["message"]["content"]
        except urllib.error.URLError as exc:
            return f"[CodeExecutorTool] HTTP error calling claude-max-proxy at {proxy_url}: {exc}"
        except (KeyError, json.JSONDecodeError) as exc:
            return f"[CodeExecutorTool] Response parse error: {exc}"
