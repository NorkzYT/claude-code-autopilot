"""Creative crew — writing, brainstorming, design, and ideation tasks using Codex."""
from __future__ import annotations

import os

from crewai import Agent, Crew, LLM, Process, Task

CREW_NAME = "creative"


def _llm() -> LLM:
    model = os.getenv("ENGINEERING_MODEL", "gpt-5.3-codex")
    mode = os.getenv("CREWAI_LLM_MODE", "direct").strip().lower()
    if mode == "proxy":
        return LLM(
            model=model,
            base_url=os.getenv("OPENAI_BASE_URL", "http://127.0.0.1:8317/v1"),
            api_key=os.getenv("OPENAI_API_KEY", os.getenv("CLI_PROXY_API_KEY", "")),
        )
    return LLM(model=model)


def run(task_description: str, **kwargs) -> str:
    llm = _llm()
    ideator = Agent(
        role="Creative Director",
        goal="Generate innovative ideas, compelling content, and creative strategies.",
        backstory=(
            "You are a seasoned creative director with expertise in writing, "
            "design thinking, and content strategy. You produce original, "
            "engaging outputs tailored to the audience and goals provided."
        ),
        llm=llm,
        verbose=True,
    )
    task = Task(
        description=task_description,
        agent=ideator,
        expected_output=(
            "A creative output matching the task — could be written content, "
            "an ideation list, a design brief, or a structured proposal."
        ),
    )
    crew = Crew(agents=[ideator], tasks=[task], process=Process.sequential, verbose=True)
    result = crew.kickoff()
    return str(result)
