"""Research crew — deep research and synthesis tasks using Codex."""
from __future__ import annotations

import os

from crewai import Agent, Crew, LLM, Process, Task

CREW_NAME = "research"


def _llm() -> LLM:
    model = os.getenv("ENGINEERING_MODEL", "gpt-5.3-codex")
    mode = os.getenv("CREWAI_LLM_MODE", "direct").strip().lower()
    if mode == "proxy":
        return LLM(
            model=model,
            base_url=os.getenv("OPENAI_BASE_URL", "http://127.0.0.1:8317/v1"),
            api_key=os.getenv("OPENAI_API_KEY", os.getenv("CLI_PROXY_API_KEY", "")),
        )
    return LLM(model=model)


def run(task_description: str, **kwargs) -> str:
    llm = _llm()
    researcher = Agent(
        role="Research Analyst",
        goal="Conduct thorough research and produce a comprehensive, well-structured summary.",
        backstory=(
            "You are a meticulous research analyst who synthesizes information "
            "from multiple angles, identifies key facts, and structures findings clearly. "
            "You cite your reasoning and surface actionable insights."
        ),
        llm=llm,
        verbose=True,
    )
    task = Task(
        description=task_description,
        agent=researcher,
        expected_output=(
            "A structured research report with: executive summary, key findings, "
            "supporting details, and actionable next steps."
        ),
    )
    crew = Crew(agents=[researcher], tasks=[task], process=Process.sequential, verbose=True)
    result = crew.kickoff()
    return str(result)
