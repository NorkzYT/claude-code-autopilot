"""
Crew registry — loads public and private domain crews at runtime.

Public crews (research, creative) ship with the scaffold.
Private crews live in  <workspace>/.crewai/crews/private/*.py
and are never committed (that directory is gitignored).

Each crew module must expose:
    CREW_NAME: str               # the routing key (e.g. "research")
    def run(task_description: str, **kwargs) -> str: ...
"""
from __future__ import annotations

import importlib.util
import os
import sys
from pathlib import Path
from types import ModuleType
from typing import Callable

_REGISTRY: dict[str, Callable[..., str]] = {}


def _load_module(path: Path, name: str) -> ModuleType | None:
    spec = importlib.util.spec_from_file_location(name, path)
    if spec is None or spec.loader is None:
        return None
    module = importlib.util.module_from_spec(spec)
    sys.modules[name] = module
    try:
        spec.loader.exec_module(module)  # type: ignore[attr-defined]
        return module
    except Exception as exc:  # noqa: BLE001
        print(f"[crew-loader] failed to load {path}: {exc}", file=sys.stderr)
        return None


def _register_public_crews() -> None:
    from . import creative, research

    for mod in (research, creative):
        if hasattr(mod, "run") and callable(mod.run):
            name: str = getattr(mod, "CREW_NAME", mod.__name__.rsplit(".", 1)[-1])
            _REGISTRY[name] = mod.run


def _register_private_crews() -> None:
    private_dir_env = os.getenv("CREWAI_PRIVATE_DIR", "").strip()
    if private_dir_env:
        private_dir = Path(private_dir_env)
    else:
        workspace = os.getenv("CREWAI_WORKSPACE", os.getcwd())
        private_dir = Path(workspace) / ".crewai" / "crews" / "private"

    if not private_dir.is_dir():
        return

    for py_file in sorted(private_dir.glob("*.py")):
        if py_file.name.startswith("_"):
            continue
        module_name = f"_private_crew_{py_file.stem}"
        module = _load_module(py_file, module_name)
        if module is None:
            continue
        if not (hasattr(module, "run") and callable(module.run)):
            print(
                f"[crew-loader] skipping {py_file.name}: no run() function found",
                file=sys.stderr,
            )
            continue
        name = getattr(module, "CREW_NAME", py_file.stem)
        _REGISTRY[name] = module.run
        print(f"[crew-loader] loaded private crew '{name}' from {py_file.name}", file=sys.stderr)


def load_all() -> dict[str, Callable[..., str]]:
    if not _REGISTRY:
        _register_public_crews()
        _register_private_crews()
    return _REGISTRY


def get(name: str) -> Callable[..., str] | None:
    load_all()
    return _REGISTRY.get(name)


def list_crews() -> list[str]:
    load_all()
    return sorted(_REGISTRY.keys())
