from __future__ import annotations

import argparse
import os
import re
import sys
from pathlib import Path

from dotenv import load_dotenv

from .crew import EngineeringPlannerCrew

CODING_TYPES = frozenset({"coding", "code", "engineering", ""})


def _has_provider_key() -> bool:
    mode = os.getenv("CREWAI_LLM_MODE", "direct").strip().lower()
    if mode == "proxy":
        return bool(
            os.getenv("OPENAI_API_KEY")
            or os.getenv("CLI_PROXY_API_KEY")
            or os.getenv("ANTHROPIC_API_KEY")
            or os.getenv("GEMINI_API_KEY")
        )
    return any(
        os.getenv(key)
        for key in (
            "OPENAI_API_KEY",
            "ANTHROPIC_API_KEY",
            "GEMINI_API_KEY",
            "GROQ_API_KEY",
            "MISTRAL_API_KEY",
            "AZURE_OPENAI_API_KEY",
        )
    )


def _slugify(text: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    slug = re.sub(r"-+", "-", slug)
    return slug or "task"


def _read_context_files(paths: list[str]) -> str:
    chunks: list[str] = []
    for raw in paths:
        path_str = raw.strip()
        if not path_str:
            continue
        path = Path(path_str).expanduser()
        if not path.exists():
            chunks.append(f"# {path_str}\n[file not found]\n")
            continue
        try:
            body = path.read_text(encoding="utf-8")
        except (OSError, UnicodeDecodeError) as exc:
            chunks.append(f"# {path_str}\n[unreadable: {exc}]\n")
            continue
        chunks.append(f"# {path_str}\n{body}\n")
    return "\n".join(chunks) if chunks else "(none)"


def _resolve_output_path(task_description: str) -> Path | None:
    out_env = os.getenv("ENGINEERING_PLAN_OUTPUT", "").strip()
    if out_env:
        return Path(out_env).expanduser()

    base_env = os.getenv("ENGINEERING_PLAN_BASE_DIR", "").strip()
    if not base_env:
        return None

    slug = _slugify(task_description)[:60] or "task"
    return Path(base_env).expanduser() / slug / "PRD.md"


def _write_output(text: str, task_description: str) -> None:
    out_path = _resolve_output_path(task_description)
    if out_path is not None:
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(text, encoding="utf-8")
        print(f"# Output written to {out_path}", file=sys.stderr)
    print(text)


def run() -> None:
    parser = argparse.ArgumentParser(
        description="Run a CrewAI crew on a single task."
    )
    parser.add_argument(
        "--task",
        required=True,
        help="Task description string.",
    )
    parser.add_argument(
        "--type",
        default="",
        dest="task_type",
        help=(
            "Crew type to use: coding|research|creative|personal|marketing|auto. "
            "Default (empty or 'coding') runs the engineering planner crew."
        ),
    )
    parser.add_argument(
        "--context-files",
        default="",
        help="Optional comma-separated file paths to include as context.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Skip the LLM call and print the inputs that would be sent.",
    )
    args = parser.parse_args()

    load_dotenv()
    mode = os.getenv("CREWAI_LLM_MODE", "direct").strip().lower()
    if mode == "proxy":
        proxy_key = os.getenv("CLI_PROXY_API_KEY", "").strip()
        proxy_base = os.getenv("CLI_PROXY_BASE_URL", "").strip()
        if proxy_key and not os.getenv("OPENAI_API_KEY"):
            os.environ["OPENAI_API_KEY"] = proxy_key
        if proxy_base and not os.getenv("OPENAI_BASE_URL"):
            os.environ["OPENAI_BASE_URL"] = proxy_base
        if proxy_base and not os.getenv("OPENAI_API_BASE"):
            os.environ["OPENAI_API_BASE"] = proxy_base

    task_type = (args.task_type or "").strip().lower()
    is_coding = task_type in CODING_TYPES

    context_paths = [p for p in args.context_files.split(",") if p.strip()]

    if args.dry_run:
        crew_label = "EngineeringPlannerCrew" if is_coding else f"router.dispatch(type={task_type!r})"
        print(f"# Dry run — inputs for {crew_label}")
        print(f"task: {args.task}")
        print(f"type: {task_type or '(engineering planner)'}")
        if context_paths:
            print("context_files:")
            print(_read_context_files(context_paths))
        return

    if not _has_provider_key():
        print(
            "ERROR: no LLM provider key found. Set OPENAI_API_KEY / "
            "CLI_PROXY_API_KEY in .env, or pass --dry-run.",
            file=sys.stderr,
        )
        sys.exit(1)

    # Coding / engineering path — EngineeringPlannerCrew
    if is_coding:
        inputs = {
            "task_description": args.task,
            "context_files": _read_context_files(context_paths),
        }
        result = EngineeringPlannerCrew().crew().kickoff(inputs=inputs)
        _write_output(str(result), args.task)
        return

    # Non-coding path — router dispatches to the appropriate domain crew
    from .router import dispatch

    workspace = os.getenv("CREWAI_WORKSPACE", "").strip()
    result_text = dispatch(args.task, task_type, workspace=workspace)
    _write_output(result_text, args.task)


if __name__ == "__main__":
    run()
