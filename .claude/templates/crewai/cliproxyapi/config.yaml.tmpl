# CLIProxyAPI config for local CrewAI usage.
# Reference: https://github.com/router-for-me/CLIProxyAPI

host: ""
port: 8317
auth-dir: "/app/auths"

# Local API keys accepted by the proxy.
# Use one of these in .crewai/.env as OPENAI_API_KEY.
api-keys:
  - "{{PROJECT_SLUG}}-crewai-local-key"

remote-management:
  allow-remote: false
  secret-key: "change-this-remote-secret"
  disable-control-panel: false

disable-signature-verification: false

# Optional management password used by some builds.
password: "change-this-ui-password"

