.PHONY: help update build rebuild rebuild-proxy start start-host stop restart restart-host logs logs-viewer status shell clean \
       add-origins verify-vnc config-get approve-device \
       auth-anthropic auth-openai auth-gh models dashboard-url config-set doctor \
       add-agent update-agent setup-discord setup-discord-scale \
       viewer-url models-status channels-status \
       hooks-list hooks-enable \
       cron-list cron-runs \
       memory-search memory-status memory-reindex \
       crewai-workflow crewai-proxy-up crewai-proxy-down crewai-proxy-status \
       ralph-once ralph-afk \
       set-timeout

SHELL := /bin/bash
-include .env

COMPOSE_FILE := docker-compose.openclaw.yml
HOST_COMPOSE := -f $(COMPOSE_FILE) -f docker-compose.host-network.yml
GATEWAY_CONTAINER := openclaw-gateway
VIEWER_CONTAINER := openclaw-browser-viewer
EXEC := docker exec -it $(GATEWAY_CONTAINER) gosu node bash -c 'umask 0022 && exec "$$@"' --
EXEC_T := docker exec $(GATEWAY_CONTAINER) gosu node bash -c 'umask 0022 && exec "$$@"' --
BOOTSTRAP_DIR := .claude/bootstrap

# Default target - show available commands
help:
	@echo "OpenClaw Docker Management Commands"
	@echo "===================================="
	@echo ""
	@echo "  make update        - Pull latest image, rebuild gateway + proxy, and restart"
	@echo "  make build         - Rebuild the gateway image"
	@echo "  make rebuild       - Force rebuild (no cache) and recreate container"
	@echo "  make rebuild-proxy - Force rebuild claude-max-proxy and recreate container"
	@echo "  make start         - Start all containers"
	@echo "  make start-host    - Start with host networking (access host localhost)"
	@echo "  make stop          - Stop all containers"
	@echo "  make restart       - Restart all containers"
	@echo "  make restart-host  - Restart with host networking"
	@echo "  make logs          - Show gateway logs (follow)"
	@echo "  make logs-viewer   - Show browser viewer logs (follow)"
	@echo "  make status        - Show container status"
	@echo "  make shell         - Open shell in gateway container"
	@echo "  make clean         - Stop and remove containers, networks, volumes"
	@echo "  make approve-device  - Approve the latest pending device"
	@echo "  make add-origins   - Configure allowed origins for Tailscale access"
	@echo "  make verify-vnc    - Verify VNC server is running"
	@echo "  make config-get    - Show current gateway config"
	@echo ""
	@echo "OpenClaw CLI (via docker exec):"
	@echo "  make auth-anthropic      - Authenticate Anthropic provider (interactive)"
	@echo "  make auth-openai         - Authenticate OpenAI Codex provider (interactive)"
	@echo "  make auth-gh             - Authenticate gh CLI inside claude-max-proxy (interactive)"
	@echo "  make models              - List available models"
	@echo "  make dashboard-url       - Print dashboard URL with token"
	@echo "  make config-set          - Set config key (usage: make config-set KEY=... VALUE=...)"
	@echo "  make doctor              - Run openclaw doctor"
	@echo ""
	@echo "Bootstrap:"
	@echo "  make add-agent           - Register agent"
	@echo "                             Usage: make add-agent AGENT=name REPO=/path/to/repo"
	@echo "  make update-agent        - Re-provision agent templates (--force)"
	@echo "                             Usage: make update-agent AGENT=name REPO=/path/to/repo"
	@echo "  make setup-discord       - Set up Discord bot channel (interactive)"
	@echo "  make setup-discord-scale - Set up Discord scaling/lanes (interactive)"
	@echo ""
	@echo "OpenClaw Status & Info:"
	@echo "  make viewer-url          - Print browser viewer URL"
	@echo "  make models-status       - Show model provider status"
	@echo "  make channels-status     - Show channel connection status"
	@echo ""
	@echo "OpenClaw Hooks:"
	@echo "  make hooks-list          - List available hooks"
	@echo "  make hooks-enable        - Enable a hook (usage: make hooks-enable HOOK=<name>)"
	@echo ""
	@echo "OpenClaw Cron:"
	@echo "  make cron-list           - List cron jobs"
	@echo "  make cron-runs           - Show recent cron runs"
	@echo ""
	@echo "OpenClaw Memory/RAG:"
	@echo "  make memory-search       - Search memory (usage: make memory-search QUERY=\"...\")"
	@echo "  make memory-status       - Show memory/RAG status"
	@echo "  make memory-reindex      - Reindex memory/RAG"
	@echo ""
	@echo "CrewAI (host-side):"
	@echo "  make crewai-workflow     - Run CrewAI workflow (usage: make crewai-workflow GOAL=\"...\")"
	@echo "  make crewai-proxy-up     - Start CrewAI CLI proxy"
	@echo "  make crewai-proxy-down   - Stop CrewAI CLI proxy"
	@echo "  make crewai-proxy-status - Show CrewAI CLI proxy status"
	@echo ""
	@echo "Ralph (multi-session iteration):"
	@echo "  make ralph-once          - Single Ralph iteration (usage: make ralph-once PRD=./PRD.md)"
	@echo "  make ralph-afk           - AFK Ralph loop (usage: make ralph-afk PRD=./PRD.md ITERATIONS=15)"
	@echo ""
	@echo "Agent Timeout:"
	@echo "  make set-timeout         - Set agent run timeout (usage: make set-timeout TIMEOUT=7200)"
	@echo ""
	@echo "Claude Max Proxy:"
	@echo "  make think LEVEL=high    - Set thinking budget for claude-max-proxy"
	@echo "                             (off | low | medium | high | xhigh | max)"
	@echo ""

# Update OpenClaw: pull latest base image, rebuild, restart, run internal update
update:
	@echo "Updating OpenClaw..."
	docker compose -f $(COMPOSE_FILE) build --pull openclaw-gateway claude-max-proxy
	docker compose -f $(COMPOSE_FILE) up -d --force-recreate openclaw-gateway claude-max-proxy
	@echo "Waiting for gateway to start..."
	@sleep 10
	@echo "Running OpenClaw internal update..."
	@$(EXEC_T) openclaw update 2>/dev/null || echo "  (openclaw update not available — skipped)"
	@echo "✅ Update complete!"
	@echo ""
	@make status

# Build the gateway image
build:
	@echo "Building gateway image..."
	docker compose -f $(COMPOSE_FILE) build openclaw-gateway
	@echo "✅ Build complete!"

# Force rebuild without cache and recreate container
rebuild:
	@echo "Force rebuilding gateway (no cache)..."
	docker compose -f $(COMPOSE_FILE) build --no-cache --pull openclaw-gateway
	@echo "Recreating container with new image..."
	docker compose -f $(COMPOSE_FILE) up -d --force-recreate openclaw-gateway
	@echo "✅ Rebuild and recreate complete!"
	@sleep 10
	@make status

# Force rebuild claude-max-proxy (no cache) and recreate container
rebuild-proxy:
	@echo "Force rebuilding claude-max-proxy (no cache)..."
	docker compose -f $(COMPOSE_FILE) build --no-cache --pull claude-max-proxy
	@echo "Recreating container with new image..."
	docker compose -f $(COMPOSE_FILE) up -d --force-recreate claude-max-proxy
	@echo "✅ Proxy rebuild and recreate complete!"
	@sleep 5
	@docker ps --filter "name=claude-max-proxy" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"

# Start containers
start:
	@echo "Starting OpenClaw containers..."
	docker compose -f $(COMPOSE_FILE) up -d
	@echo "✅ Containers started!"
	@sleep 5
	@make status

# Start containers with host networking (container shares host localhost)
start-host:
	@echo "Starting OpenClaw with host networking..."
	docker compose $(HOST_COMPOSE) up -d
	@echo "Host network mode active — container shares host localhost."
	@sleep 5
	@make status

# Stop containers
stop:
	@echo "Stopping OpenClaw containers..."
	docker compose -f $(COMPOSE_FILE) stop
	@echo "✅ Containers stopped!"

# Restart containers (recreate to pick up new images after build)
restart:
	@echo "Restarting OpenClaw containers..."
	docker compose -f $(COMPOSE_FILE) up -d --force-recreate
	@echo "Waiting for startup..."
	@sleep 10
	@make status

# Restart containers with host networking
restart-host:
	@echo "Restarting OpenClaw with host networking..."
	docker compose $(HOST_COMPOSE) up -d --force-recreate
	@echo "Waiting for startup..."
	@sleep 10
	@make status

# Show gateway logs
logs:
	docker compose -f $(COMPOSE_FILE) logs -f $(GATEWAY_CONTAINER)

# Show browser viewer logs
logs-viewer:
	docker compose -f $(COMPOSE_FILE) logs -f $(VIEWER_CONTAINER)

# Show container status
status:
	@echo "OpenClaw Container Status:"
	@echo "=========================="
	@docker ps --filter "name=openclaw" --filter "name=claude-max-proxy" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
	@echo ""
	@echo "VNC Processes:"
	@echo "=============="
	@docker exec $(GATEWAY_CONTAINER) ps aux | grep -E "Xvfb|x11vnc|fluxbox" | grep -v grep || echo "⚠️  VNC processes not running"

# Open shell in gateway container
shell:
	docker exec -it $(GATEWAY_CONTAINER) gosu node bash

# Clean up everything
clean:
	@echo "⚠️  This will stop and remove all OpenClaw containers, networks, and volumes!"
	@read -p "Continue? [y/N] " -n 1 -r; \
	echo; \
	if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
		docker compose -f $(COMPOSE_FILE) down -v; \
		echo "✅ Cleanup complete!"; \
	else \
		echo "Cancelled."; \
	fi

# Configure allowed origins (localhost + OPENCLAW_EXTRA_ORIGINS from .env)
add-origins:
	@echo "Configuring allowed origins..."
	@PORT=$(OPENCLAW_GATEWAY_PORT); PORT=$${PORT:-18789}; \
	ORIGINS='["http://localhost:'$$PORT'","http://127.0.0.1:'$$PORT'"'; \
	if [ -n "$(OPENCLAW_EXTRA_ORIGINS)" ]; then \
		IFS=',' ; for origin in $(OPENCLAW_EXTRA_ORIGINS); do \
			ORIGINS="$$ORIGINS,\"$$origin\""; \
		done; \
	fi; \
	ORIGINS="$$ORIGINS]"; \
	echo "  Origins: $$ORIGINS"; \
	$(EXEC_T) openclaw config set gateway.controlUi.allowedOrigins "$$ORIGINS" --json
	@docker exec $(GATEWAY_CONTAINER) chown node:node /home/node/.openclaw/openclaw.json 2>/dev/null || true
	@echo "Restarting gateway to apply..."
	@docker compose -f $(COMPOSE_FILE) up -d --force-recreate $(GATEWAY_CONTAINER) >/dev/null 2>&1
	@sleep 10
	@echo "✅ Origins configured!"
	@echo ""
	@echo "Current origins:"
	@docker exec $(GATEWAY_CONTAINER) gosu node openclaw config get gateway.controlUi.allowedOrigins 2>/dev/null || echo "  (gateway still starting — run 'make status' to check)"

# Verify VNC server is running
verify-vnc:
	@echo "VNC Server Status:"
	@echo "=================="
	@docker exec $(GATEWAY_CONTAINER) ps aux | grep -E "Xvfb|x11vnc|fluxbox" | grep -v grep || echo "❌ VNC processes not running"
	@echo ""
	@echo "x11vnc Log (last 10 lines):"
	@echo "==========================="
	@docker exec $(GATEWAY_CONTAINER) tail -10 /tmp/x11vnc.log 2>/dev/null || echo "No x11vnc log found"

# Show current gateway config
config-get:
	@echo "Current Gateway Configuration:"
	@echo "=============================="
	@$(EXEC_T) openclaw config get gateway

# Authenticate Anthropic provider (interactive)
auth-anthropic:
	$(EXEC) openclaw models auth paste-token --provider anthropic

# Authenticate OpenAI Codex provider (interactive)
auth-openai:
	$(EXEC) openclaw models auth login --provider openai-codex

# Authenticate gh CLI inside claude-max-proxy (interactive).
# Writes to the mounted ~/.config/gh so commits + pushes made by the proxy's
# claude subprocesses run as the gh-authenticated user. After this the
# container's system-wide git credential helper (`gh auth git-credential`)
# handles HTTPS pushes automatically.
auth-gh:
	@mkdir -p $${HOME}/.config/gh
	docker exec -it claude-max-proxy gh auth login

# List available models
models:
	@$(EXEC_T) openclaw models list

# Print dashboard URL with token
dashboard-url:
	@$(EXEC_T) openclaw dashboard

# Set a config key: make config-set KEY=gateway.bind VALUE=lan
config-set:
	@if [ -z "$(KEY)" ] || [ -z "$(VALUE)" ]; then \
		echo "Error: Missing required variables"; \
		echo "Usage: make config-set KEY=<key> VALUE=<value>"; \
		echo "Example: make config-set KEY=gateway.bind VALUE=lan"; \
		exit 1; \
	fi
	@$(EXEC_T) openclaw config set $(KEY) $(VALUE)

# Run openclaw doctor
doctor:
	@$(EXEC_T) openclaw doctor

# Approve the latest pending device request
approve-device:
	@REQUEST_ID=$$($(EXEC_T) openclaw devices list 2>/dev/null \
		| grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' \
		| tail -1); \
	if [ -z "$$REQUEST_ID" ]; then \
		echo "No pending device requests."; \
	else \
		echo "Approving request: $$REQUEST_ID"; \
		$(EXEC_T) openclaw devices approve "$$REQUEST_ID"; \
	fi

# Register an agent: make add-agent AGENT=myproject REPO=/path/to/project
add-agent:
	@if [ -z "$(AGENT)" ] || [ -z "$(REPO)" ]; then \
		echo "Error: Missing required variables"; \
		echo "Usage: make add-agent AGENT=<agent-name> REPO=<path>"; \
		echo "Example: make add-agent AGENT=myproject REPO=/path/to/project"; \
		echo "Optional: AGENT_OPTS='--force --emoji 🚀'"; \
		exit 1; \
	fi
	bash $(BOOTSTRAP_DIR)/add_openclaw_agent.sh $(AGENT) $(REPO) $(AGENT_OPTS)

# Re-provision agent persona files after template/prompt changes: make update-agent AGENT=myproject REPO=/path/to/project
update-agent:
	@if [ -z "$(AGENT)" ] || [ -z "$(REPO)" ]; then \
		echo "Error: Missing required variables"; \
		echo "Usage: make update-agent AGENT=<agent-name> REPO=<path>"; \
		echo "Example: make update-agent AGENT=myproject REPO=/path/to/project"; \
		exit 1; \
	fi
	bash $(BOOTSTRAP_DIR)/add_openclaw_agent.sh $(AGENT) $(REPO) --force $(AGENT_OPTS)

# Set up Discord bot channel (interactive)
setup-discord:
	bash $(BOOTSTRAP_DIR)/openclaw_discord_setup.sh

# Set up Discord scaling/lanes (interactive)
setup-discord-scale:
	bash $(BOOTSTRAP_DIR)/openclaw_discord_scale_setup.sh

# ─── OpenClaw Status & Info ──────────────────────────────────────────

# Print browser viewer URL
viewer-url:
	@$(EXEC_T) openclaw viewer-url 2>/dev/null || echo "Viewer not available. Check: make status"

# Show model provider status
models-status:
	@$(EXEC_T) openclaw models status

# Show channel connection status
channels-status:
	@$(EXEC_T) openclaw channels status

# ─── OpenClaw Hooks ──────────────────────────────────────────────────

# List available hooks
hooks-list:
	@$(EXEC_T) openclaw hooks list

# Enable a hook: make hooks-enable HOOK=session-memory
hooks-enable:
	@if [ -z "$(HOOK)" ]; then \
		echo "Usage: make hooks-enable HOOK=<hook-name>"; \
		echo "Available hooks: make hooks-list"; \
		exit 1; \
	fi
	@$(EXEC_T) openclaw hooks enable $(HOOK)

# ─── OpenClaw Cron ───────────────────────────────────────────────────

# List cron jobs
cron-list:
	@$(EXEC_T) openclaw cron list

# Show recent cron runs
cron-runs:
	@$(EXEC_T) openclaw cron runs

# ─── OpenClaw Memory/RAG ────────────────────────────────────────────

# Search memory/RAG: make memory-search QUERY="deployment process"
memory-search:
	@if [ -z "$(QUERY)" ]; then \
		echo "Usage: make memory-search QUERY=\"<search query>\""; \
		exit 1; \
	fi
	@$(EXEC_T) openclaw memory search "$(QUERY)"

# Show memory/RAG status
memory-status:
	@$(EXEC_T) openclaw memory status

# Reindex memory/RAG
memory-reindex:
	@$(EXEC_T) openclaw memory reindex

# ─── CrewAI (host-side) ─────────────────────────────────────────────

# Run CrewAI workflow: make crewai-workflow GOAL="Your goal here"
crewai-workflow:
	@if [ -z "$(GOAL)" ]; then \
		echo "Usage: make crewai-workflow GOAL=\"Your goal here\""; \
		exit 1; \
	fi
	@bash .claude/scripts/crewai-local-workflow.sh --goal "$(GOAL)"

# Start CrewAI CLI proxy
crewai-proxy-up:
	@bash .claude/scripts/crewai-cliproxyapi.sh up

# Stop CrewAI CLI proxy
crewai-proxy-down:
	@bash .claude/scripts/crewai-cliproxyapi.sh down

# Show CrewAI CLI proxy status
crewai-proxy-status:
	@bash .claude/scripts/crewai-cliproxyapi.sh status

# ─── Ralph (multi-session iteration) ────────────────────────────────

# Single Ralph iteration: make ralph-once PRD=./PRD.md
ralph-once:
	@if [ -z "$(PRD)" ]; then \
		echo "Usage: make ralph-once PRD=./path/to/PRD.md"; \
		exit 1; \
	fi
	@bash .claude/scripts/ralph-once.sh . $(PRD)

# Multi-iteration Ralph loop: make ralph-afk PRD=./PRD.md ITERATIONS=15
ralph-afk:
	@if [ -z "$(PRD)" ]; then \
		echo "Usage: make ralph-afk PRD=./PRD.md ITERATIONS=15"; \
		exit 1; \
	fi
	@bash .claude/scripts/afk-ralph.sh --prd $(PRD) --iterations $(or $(ITERATIONS),10)

# ─── Agent Timeout ───────────────────────────────────────────────────

# Set agent run timeout: make set-timeout TIMEOUT=7200
set-timeout:
	@TIMEOUT=$${TIMEOUT:-7200}; \
	$(EXEC_T) openclaw config set agents.defaults.timeoutSeconds $$TIMEOUT; \
	echo "Agent timeout set to $${TIMEOUT}s"

# ─── Claude Max Proxy Thinking Budget ────────────────────────────────

# Set the default thinking budget applied to every proxy request.
# Usage: make think LEVEL=high   (off | low | medium | high | xhigh | max)
think:
	@PROXY_URL="http://localhost:$${CLAUDE_MAX_PROXY_PORT:-3456}/admin/thinking-budget"; \
	if [ -z "$(LEVEL)" ]; then \
		echo "Usage: make think LEVEL=<level>"; \
		echo "Levels: off, low, medium, high, xhigh, max"; \
		echo "Current:"; \
		curl -s "$$PROXY_URL"; echo; \
	else \
		curl -s -X POST "$$PROXY_URL" \
			-H 'Content-Type: application/json' \
			-d '{"budget": "$(LEVEL)"}'; echo; \
	fi
